<?xml version="1.0"?>
<!--
  Amiga minimal URDF — base_link + velodyne only (no wheel joints).

  Geometry reference (APPROXIMATE — measure your physical robot and update):
    Robot footprint : ~1.10 m (L) × 0.93 m (W)
    Robot height    : ~0.76 m to top of frame
    Wheel diameter  : ~0.38 m  →  wheel axle at z = 0.19 m above ground
    base_link       : center of footprint, at GROUND LEVEL (z = 0)
    velodyne origin : where the VLP-16 spin axis intersects the sensor base

  base_link → velodyne transform (2026-07 forward-facing re-mount):
    x  =  0.85 m   (LiDAR is 1 ft / 0.30 m forward of the front-tire centres,
                    which sit ~0.55 m ahead of base_link = half the ~1.10 m
                    wheelbase; confirm the half-wheelbase if it differs)
    y  =  0.000 m  (centred on robot centreline)
    z  =  0.800 m  (LiDAR spin axis height above ground; tape, robot on wheels)
    roll  = 0  rad
    pitch = -0.262 rad (~15° nose-down) FOR THE RAW-CLOUD ROS STACK — the native
                    brain stack corrects the cloud itself so it uses identity here
    yaw   = 0  rad  (forward-facing; LiDAR front aligns with robot +X/forward)
    NB: this unit is a VLP-16 Puck Hi-Res (±10°) — see lidar/lidar_driver.py

  After measuring, update the <origin> below AND the matching static TF args in
  launch/tf_static_base_to_velodyne.launch.py.
-->
<robot name="amiga_min">

  <!-- ===== base_link ===== -->
  <!-- Origin at ground-level center of robot footprint.
       Visual box starts at ground (z=0) and extends 0.76 m upward. -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.38" rpy="0 0 0"/>
      <geometry>
        <!-- Approximate Amiga frame: 1.10 m long, 0.93 m wide, 0.76 m tall -->
        <box size="1.10 0.93 0.76"/>
      </geometry>
      <material name="grey">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.38" rpy="0 0 0"/>
      <geometry>
        <box size="1.10 0.93 0.76"/>
      </geometry>
    </collision>
    <inertial>
      <!-- Approximate total mass ~75 kg; moments estimated for a rigid box body -->
      <mass value="75.0"/>
      <origin xyz="0 0 0.38" rpy="0 0 0"/>
      <inertia ixx="5.0" ixy="0.0" ixz="0.0"
               iyy="8.0" iyz="0.0"
               izz="10.0"/>
    </inertial>
  </link>

  <!-- ===== velodyne ===== -->
  <!-- Small cylinder representing the VLP-16 body (Ø=103 mm, H=72 mm).
       Origin is at the bottom face of the sensor (= mounting surface). -->
  <link name="velodyne">
    <visual>
      <origin xyz="0 0 0.036" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.072" radius="0.052"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.036" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.072" radius="0.052"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.83"/>
      <origin xyz="0 0 0.036" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- ===== base_link → velodyne (fixed joint) ===== -->
  <!--
    2026-07 forward-facing re-mount:
  x = 0.85 m   (1 ft forward of the front-tire centres, which are ~0.55 m ahead
               of base_link = half the ~1.10 m wheelbase)
  y = 0.000 m  (centered on robot centreline)
  z = 0.800 m  (LiDAR spin axis height above ground; tape, robot on wheels)
  yaw = 0  (forward-facing).  pitch here is 0 for the visual URDF; the ~15°
           nose-down mount pitch belongs in the RAW-cloud ROS TF, not here.
    Matches tf_static_base_to_velodyne.launch.py.
  -->
  <joint name="base_to_velodyne" type="fixed">
    <parent link="base_link"/>
    <child link="velodyne"/>
    <origin xyz="0.85 0.0 0.800" rpy="0 0 0"/>
  </joint>

</robot>
